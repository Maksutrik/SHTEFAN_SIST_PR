using System.Text.Json;

int id = 1;

// Список минимум из 10 аргументов, некоторые повторяются
List<Person> users = new List<Person>
{
    new() { Id = id++, Name = "Tom", Age = 25 },
    new() { Id = id++, Name = "Bob", Age = 30 },
    new() { Id = id++, Name = "Alice", Age = 22 },
    new() { Id = id++, Name = "Tom", Age = 28 },      // повторяющееся имя Tom
    new() { Id = id++, Name = "David", Age = 35 },
    new() { Id = id++, Name = "Emma", Age = 27 },
    new() { Id = id++, Name = "Bob", Age = 33 },      // повторяющееся имя Bob
    new() { Id = id++, Name = "Sophia", Age = 26 },
    new() { Id = id++, Name = "Tom", Age = 29 },      // повторяющееся имя Tom
    new() { Id = id++, Name = "Oliver", Age = 31 }
};

var builder = WebApplication.CreateBuilder(args);
var app = builder.Build();

// GET: получение всех пользователей
app.MapGet("/api/users", () => users);

// GET: получение пользователя по id
app.MapGet("/api/users/{id}", (int id) =>
{
    Person? user = users.FirstOrDefault(u => u.Id == id);
    if (user == null) return Results.NotFound(new { message = "Пользователь не найден" });
    return Results.Json(user);
});

// DELETE: удаление пользователя
app.MapDelete("/api/users/{id}", (int id) =>
{
    Person? user = users.FirstOrDefault(u => u.Id == id);
    if (user == null) return Results.NotFound(new { message = "Пользователь не найден" });
    users.Remove(user);
    return Results.Json(user);
});

// POST: добавление пользователя
app.MapPost("/api/users", (Person user) =>
{
    user.Id = id++;
    users.Add(user);
    return user;
});

// PUT: изменение пользователя
app.MapPut("/api/users", (Person userData) =>
{
    var user = users.FirstOrDefault(u => u.Id == userData.Id);
    if (user == null) return Results.NotFound(new { message = "Пользователь не найден" });
    user.Age = userData.Age;
    user.Name = userData.Name;
    return Results.Json(user);
});

app.Run();

public class Person
{
    public int Id { get; set; }
    public string Name { get; set; } = "";
    public int Age { get; set; }
}






